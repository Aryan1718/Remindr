APP_NAME=Fatigue-Aware Personal Assistant Backend
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api/v1
LOG_LEVEL=INFO
ALLOWED_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=
SUPABASE_URL=
SUPABASE_JWT_SECRET=
SUPABASE_JWT_ISSUER=
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUDIENCE=authenticated
FRONTEND_BASE_URL=http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/v1/connectors/google-calendar/oauth/callback
GOOGLE_OAUTH_SCOPES=openid https://www.googleapis.com/auth/userinfo.email https://www.googleapis.com/auth/calendar.readonly
CONNECTOR_SYNC_EAGER=true
TELEGRAM_VALIDATE_BOT_TOKENS=false
TELEGRAM_DEFAULT_WEBHOOK_BASE_URL=
